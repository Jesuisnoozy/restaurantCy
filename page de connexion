<!DOCTYPE html> 
<html lang="fr">
<head>
	<meta charset="#EE7000">
	<title> Connexion - Le Goupix</title>
	<link rel="stylesheet"
	href="style.css">
</head>

<body>
	<div class="connexion">
	<h1>Le Goupix 🌮</h1>
	<p class="subtitle"> Connexion à votre espace</p>
	
	<form class="login">
		<label for="email">Adresse e-mail</label>
		<input type="email" id="email" placeholder="exemble@gmail.com" required>
		<label for="passeword">Mot de passe</label>
		<input type="passeword" id="passeword" placeholder="*********" required>
		
		<button type="submit"> Se connecter</button>
	</form>

</div>

</body>
</html>
