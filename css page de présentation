body {
	font-style: italic;
	margin: 0;
	background-color:#000000;
	color: white;
}
header{
	background-color:#EE7000;
	color: white;
	text-align: center;
	padding: 20px;
}

.barre-de-recherche {
	text-align: center;
	margin: 20px;
}
.barre-de-recherche input {
	padding: 10px;
	width: 60%;
	border-radius: 5px;
	border: 1px solid black;
}
.filtrer ul{
	display: flex;
	justify-content: center;
	padding: 0;
	gap: 15px;
}
.filtrer a{
	color: white;
	font-weight: bold;
}

.produits {
	padding: 20px;
}
.ingrédients {
	background color: white;
	border-radius: 10px;
	padding: 15px;
}
.prix{
	front-weight: bold;
}
footer {
	text-align: center;
	padding: 15px;
}
