body {
	font-style: italic;
	margin: 0;
	background-color:#000000;
	color: white;
}

header {
	background-color:#EE7000;
	color: white;
	text-align: center;
	padding: 20px;
}

.barre-de-recherche {
	text-align: center;
	margin: 20px;
}

.barre-de-recherche input {
	padding: 10px;
	width: 60%;
}

.filters {
	display: flex;
	justify-content: center;
	margin-bottom: 30px;
}

.filters label {
	padding: 10px 15px;
	border: 2px solid;
	cursor: pointer;
	border-radius: 5px;
}

.produits {
	display: grid;
	padding: 20px;
}

.prix {
	font-weight: bold;
}

.produits article {
	display: none;
}

#all:checked ~ .produits article {
	display: block;
}

#plats:checked ~ .produits article.plats {
	display: block;
}

#desserts:checked ~ .produits article.desserts {
	display: block;
}

#boissons:checked ~ .produits article.boissons {
	display: block;
}

footer {
	text-align: center;
	padding: 15px;
}
