body {
    background-color: #4F4B40;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0;
}

}
.center {
	flex: 1;
	flex-flow:row;
}


header {
    background-color: #EE7000;
    padding: 80px 40px;
    position: sticky;
    top: 0;
    z-index: 100;
    font-style: italic;
    width: 100%;           
    box-sizing: border-box; 
}
    
.bouton {
    display: inline-block;
    padding: 20px 0px;
    border-radius: 4px;
    font-size: 1.95rem;
    cursor: pointer;
    border: none;
}

h1 {
    padding:0;              
    color: black;
    font-size: 2rem;
    text-align: center;	
    margin:0;              
    width: 100%;
    display: flex;           
    align-items: center;     
    justify-content: center; 
    background-color: #4F4B40;
    height: 100px;
}

nav { 
	display:flex;
    }

* {
    font-family: Arial, sans-serif;
}

.hero-boutons {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    background-color: #4F4B40;
}

.suis {
	text-align:center;
	font-size: 2rem;
	flex-flow:row;
}

.suisse {
	text-align:center;
}

.imgtexte {
	float: left;
	margin: 0;
}

.barre-de-recherche {
	text-align: center;
	margin: 20px;
}

.barre-de-recherche input {
	padding: 10px;
	width: 60%;
}

.filters {
	display: flex;
	justify-content: center;
	margin-bottom: 30px;
}

.filters label {
	padding: 10px 15px;
	border: 2px solid;
	cursor: pointer;
	border-radius: 5px;
}

.produits {
	display: grid;
	padding: 20px;
}

.prix {
	font-weight: bold;
}


.connexion{
	background-color: white;
	padding: 35px;
	width: 60%;           
        border-radius: 10px;     
	text-align: center;
	margin-top: 50px;
}

.connexion h1{
	background-color: #EE7000;
}

.login{
	display: flex;
	flex-direction: column;
	text-align: left;
}

footer {
	text-align: center;
	padding: 15px;
}
